# ============================================================
#  .gitignore — React (Vite) frontend + FastAPI (Python) backend
#  Educational internship project — technik programista
#  Place this file at the repository ROOT.
# ============================================================

# ----- Secrets & environment -------------------------------
# NEVER commit real secrets. Commit an example instead: .env.example
.env
.env.*
!.env.example

# ----- Node / React / Vite (frontend/) ---------------------
node_modules/
dist/
dist-ssr/
build/
.vite/
*.local
coverage/
.eslintcache
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# ----- Python / FastAPI (backend/) -------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
.Python
# Virtual environments
.venv/
venv/
env/
ENV/
# Test / type / lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/

# ----- Databases (TEST DATA ONLY — no real data!) ----------
*.db
*.sqlite
*.sqlite3

# ----- Editors / IDE ---------------------------------------
# .vscode/ is ignored for simplicity. If later you want to share
# editor config with the team, un-ignore specific files, e.g.:
#   !.vscode/extensions.json
.vscode/
.idea/
*.swp

# ----- OS files --------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini
